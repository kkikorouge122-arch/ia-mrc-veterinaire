# -*- coding: utf-8 -*-
"""
Doctoral Research Project: Deep Learning Pipeline for Brain Tumor Detection on MRI
Theme: Computer Vision in Veterinary & Biomedical Sciences
Algorithm: Convolutional Neural Network (CNN) with Transfer Learning (ResNet18)
"""

import os
import torch
import torch.nn as nn
import torch.optim as optim
from torch.utils.data import DataLoader
from torchvision import datasets, transforms, models
from sklearn.metrics import classification_report, confusion_matrix
import matplotlib.pyplot as plt
import seaborn as sns
import numpy as np

# =====================================================================
# 1. DATA PREPROCESSING AND AUGMENTATION (Pipeline Step 1)
# =====================================================================
# Data augmentation is critical in medical imaging to prevent overfitting
data_transforms = {
    'train': transforms.Compose([
        transforms.Resize((224, 224)),
        transforms.RandomHorizontalFlip(),
        transforms.RandomRotation(15),
        transforms.ToTensor(),
        transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225]) # ImageNet standards
    ]),
    'test': transforms.Compose([
        transforms.Resize((224, 224)),
        transforms.ToTensor(),
        transforms.Normalize([0.485, 0.456, 0.406], [0.229, 0.224, 0.225])
    ]),
}

# Note for users: Replace 'dataset/train' and 'dataset/test' with your Google Colab paths
# e.g., '/content/drive/MyDrive/dataset/train'
data_dir = 'dataset'
image_datasets = {x: datasets.ImageFolder(os.path.join(data_dir, x), data_transforms[x]) for x in ['train', 'test']}
dataloaders = {x: DataLoader(image_datasets[x], batch_size=32, shuffle=True, num_workers=2) for x in ['train', 'test']}

device = torch.device("cuda:0" if torch.cuda.is_available() else "cpu")
print(f"Executing pipeline on device: {device}")

# =====================================================================
# 2. MODEL ARCHITECTURE & TRANSFER LEARNING (Pipeline Step 2)
# =====================================================================
# We use ResNet18 pre-trained on ImageNet and fine-tune it for binary classification
model = models.resnet18(weights=models.ResNet18_Weights.DEFAULT)

# Freeze early layers to preserve low-level features (edges, textures)
for param in model.parameters():
    param.requires_grad = False

# Replace the final fully connected layer for our 2 classes (No Tumor vs Tumor)
num_ftrs = model.fc.in_features
model.fc = nn.Linear(num_ftrs, 2)
model = model.to(device)

criterion = nn.CrossEntropyLoss()
optimizer = optim.Adam(model.fc.parameters(), lr=0.001)

# =====================================================================
# 3. TRAINING ENGINE (Pipeline Step 3)
# =====================================================================
def train_model(model, criterion, optimizer, num_epochs=10):
    train_loss_history, train_acc_history = [], []
    
    print("--- Starting Training Loop ---")
    for epoch in range(num_epochs):
        model.train()
        running_loss = 0.0
        running_corrects = 0
        
        for inputs, labels in dataloaders['train']:
            inputs, labels = inputs.to(device), labels.to(device)
            optimizer.zero_grad()
            
            outputs = model(inputs)
            _, preds = torch.max(outputs, 1)
            loss = criterion(outputs, labels)
            
            loss.backward()
            optimizer.step()
            
            running_loss += loss.item() * inputs.size(0)
            running_corrects += torch.sum(preds == labels.data)
            
        epoch_loss = running_loss / len(image_datasets['train'])
        epoch_acc = running_corrects.double() / len(image_datasets['train'])
        
        train_loss_history.append(epoch_loss)
        train_acc_history.append(epoch_acc.cpu().item())
        
        print(f"Epoch {epoch+1}/{num_epochs} - Loss: {epoch_loss:.4f} - Acc: {epoch_acc:.4f}")
        
    return model, train_loss_history, train_acc_history

trained_model, loss_hist, acc_hist = train_model(model, criterion, optimizer, num_epochs=10)

# =====================================================================
# 4. SCIENTIFIC VALIDATION & METRICS (Pipeline Step 4)
# =====================================================================
model.eval()
all_preds, all_labels = [], []

with torch.no_grad():
    for inputs, labels in dataloaders['test']:
        inputs, labels = inputs.to(device), labels.to(device)
        outputs = model(inputs)
        _, preds = torch.max(outputs, 1)
        all_preds.extend(preds.cpu().numpy())
        all_labels.extend(labels.cpu().numpy())

print("\n=== ACADEMIC CLASSIFICATION REPORT ===")
print(classification_report(all_labels, all_preds, target_names=['No Tumor', 'Tumor']))

# Plotting Loss Curves
plt.figure(figsize=(10, 4))
plt.subplot(1, 2, 1)
plt.plot(loss_hist, color='#FF5500', label='Training Loss')
plt.title('Learning Curve: Loss')
plt.grid(True)

plt.subplot(1, 2, 2)
plt.plot(acc_hist, color='#00D2FF', label='Training Accuracy')
plt.title('Learning Curve: Accuracy')
plt.grid(True)
plt.show()
